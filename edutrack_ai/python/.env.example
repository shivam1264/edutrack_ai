# EduTrack AI - Python API Environment Variables
# ⚠️ NEVER commit .env to Git!

# ─── Google Gemini (FREE AI) ───────────────────────────────────────────────────
# Get free API key at: https://aistudio.google.com/app/apikey
# Free limits: 15 requests/min, 1 million tokens/day
# This is used as FALLBACK when Groq is unavailable
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Groq AI (PRIMARY AI - Faster & Higher Limits) ─────────────────────────────
# Get free API key at: https://console.groq.com/keys
# Free limits: Much higher than Gemini, faster inference
# Add multiple keys for automatic rotation when rate limits are hit
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here

# ─── Firebase (for Firestore sync) ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=edutrack-ai-942c2
# Download service account from Firebase Console → Project Settings → Service accounts
FIREBASE_SERVICE_ACCOUNT=service_account.json

# ─── Cloudinary (for file storage - FREE 25GB) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=dwbpbi6zu
CLOUDINARY_API_KEY=834376549841598
CLOUDINARY_API_SECRET=H76K-jFp_QJ2u6zM88rY14q7n8g
CLOUDINARY_UPLOAD_PRESET=edutrack_uploads

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8080
DEBUG=false
